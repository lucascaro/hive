   [;m│[0m  Key bindings while inside an attached tmux session.                                                           [;m│[0m   
   [;m│[0m                                                                                                                [;m│[0m   
   [;m│[0m  ctrl+q              detach from session (return to Hive)                                                      [;m│[0m   
   [;m│[0m  ctrl+b c            create a new window                                                                       [;m│[0m   
   [;m│[0m  ctrl+b n / p        next / previous window                                                                    [;m│[0m   
   [;m│[0m  ctrl+b 0-9          switch to window by number                                                                [;m│[0m   
   [;m│[0m  ctrl+b ,            rename current window                                                                     [;m│[0m   
   [;m│[0m  ctrl+b %            split pane vertically                                                                     [;m│[0m   
   [;m│[0m  ctrl+b "            split pane horizontally                                                                   [;m│[0m   
   [;m│[0m  ctrl+b arrow        navigate between panes                                                                    [;m│[0m   
   [;m│[0m  ctrl+b z            zoom/unzoom current pane                                                                  [;m│[0m   
   [;m│[0m  ctrl+b x            kill current pane                                                                         [;m│[0m   
   [;m│[0m  ctrl+b [            enter scroll/copy mode (q to exit)                                                        [;m│[0m   
   [;m│[0m  ctrl+b ]            paste from tmux buffer                                                                    [;m│[0m   
   [;m│[0m  ctrl+b ?            show all tmux key bindings                                                                [;m│[0m   
   [;m│[0m  ctrl+b t            show clock                                                                                [;m│[0m   
